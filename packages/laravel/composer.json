{
  "name": "pinoox/numera-laravel",
  "description": "Laravel integration for pinoox/numera",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "pinoox/numera": "^2.1",
    "illuminate/support": "^9.0|^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^7.0|^8.0|^9.0",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Pinoox\\Numera\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Pinoox\\Numera\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pinoox\\Numera\\Laravel\\NumeraServiceProvider"
      ],
      "aliases": {
        "Numera": "Pinoox\\Numera\\Laravel\\Facades\\Numera"
      }
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
